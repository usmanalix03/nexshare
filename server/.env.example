# ────────────────────────────────────────────────
# Server Configuration
# ────────────────────────────────────────────────
PORT=3001

# URL of the frontend (for CORS allow-list)
CLIENT_URL=http://localhost:5173

# ────────────────────────────────────────────────
# CockroachDB (PostgreSQL-compatible)
# Get this from: https://cockroachlabs.cloud → your cluster → Connect
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=verify-full
# ────────────────────────────────────────────────
DATABASE_URL=postgresql://<YOUR_COCKROACHDB_USER>:<YOUR_COCKROACHDB_PASSWORD>@<YOUR_COCKROACHDB_HOST>:26257/<YOUR_DATABASE_NAME>?sslmode=verify-full

# ────────────────────────────────────────────────
# JWT Authentication
# Generate a strong secret: openssl rand -hex 32
# ────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_strong_random_secret_minimum_32_chars

# Token expiry (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d
