# ─────────────────────────────────────────────────────────────────
# NexShare — Server Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────

# Port the server listens on (Render sets this automatically)
PORT=3001

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://nexshare.vercel.app,http://localhost:5173
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────
# CockroachDB (PostgreSQL-compatible)
# Get from: https://cockroachlabs.cloud → Cluster → Connect
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:26257/dbname?sslmode=verify-full

# ─────────────────────────────────────────────────────────────────
# JWT Authentication
# Generate a strong secret: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_32_byte_hex_secret
JWT_EXPIRES_IN=7d
